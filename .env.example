# Synthograsizer Suite — environment reference.
# Local instrument mode needs NOTHING from this file (key can live in
# ai_studio_config.json). Hosted / service deployments set these via the
# platform (Cloud Run --set-env-vars / --set-secrets), never a committed file.

# ── Core ────────────────────────────────────────────────────────────────────
# Gemini API key (AI Studio). In production this comes from Secret Manager.
GOOGLE_API_KEY=

# ── Hosted hardening (existing) ─────────────────────────────────────────────
# SYNTH_HOSTED=1          # config lockdown + rate limit + retention purge
# SYNTH_GOOGLE_API=       # pin interactions|legacy on hosted instances
# RATE_LIMIT_REQUESTS=30
# RATE_LIMIT_WINDOW_SECONDS=300
# RETENTION_DAYS=30

# ── Service mode (accounts + credits; requires SYNTH_HOSTED=1 too) ──────────
# SYNTH_AUTH=1
# GOOGLE_OAUTH_CLIENT_ID=679278101913-k4am2o8gu3dhah9n08i40lpslb7m0afs.apps.googleusercontent.com
# ADMIN_EMAILS=quittersarts@gmail.com     # comma-separated; admin = unlimited + video/music
# SYNTH_TERMS_VERSION=v0.2
# SYNTH_MONTHLY_CREDITS=300
# SESSION_TTL_DAYS=30
# SYNTH_INSECURE_COOKIES=1                # dev-only: allow cookie over http://localhost

# Database — either a full DSN (local/dev) …
# DATABASE_URL=postgresql://synth:synth@localhost:5432/synth
# … or Cloud SQL unix-socket parts (Cloud Run with --add-cloudsql-instances):
# INSTANCE_CONNECTION_NAME=synthograsizer-app:northamerica-northeast1:synth-db
# DB_USER=postgres
# DB_PASS=                                # from Secret Manager (synth-db-pass)
# DB_NAME=synth
