# Agent Chat Room - Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# REQUIRED
# ===========================================

# Google Gemini API Key
# Get your API key from: https://aistudio.google.com/app/apikey
# Calls use the Interactions API (@google/genai SDK) with store=false —
# nothing is retained server-side at Google. Required model access:
#   - gemini-3.1-pro-preview (text generation, search/URL tools)
#   - gemini-3-pro-image-preview (image analysis)
GEMINI_API_KEY=your_api_key_here

# ===========================================
# OPTIONAL
# ===========================================

# Server port (defaults to 3001)
# PORT=3001
